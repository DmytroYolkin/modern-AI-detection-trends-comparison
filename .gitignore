# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Abstra
# Abstra is an AI-powered process automation framework.
# Ignore directories containing user credentials, local state, and settings.
# Learn more at https://abstra.io/docs
.abstra/

# Visual Studio Code
#  Visual Studio Code specific template is maintained in a separate VisualStudioCode.gitignore 
#  that can be found at https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
#  and can be added to the global gitignore or merged into this file. However, if you prefer, 
#  you could uncomment the following to ignore the entire vscode folder
# .vscode/

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor
#  Cursor is an AI-powered code editor. `.cursorignore` specifies files/directories to
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/

test.py

# --- training framework artifacts ---
# Experimental / scratch checkpoints: keep the folder, ignore its contents
models/test_models/*
!models/test_models/.gitkeep
# Cached extractor feature matrices (regenerate with training/build_dataset.py)
data/features/

# --- baseline-detector artifacts (regenerate with test/compare_baselines.py) ---
# Per-detector results JSON (one per run; output of the comparison runner)
models/baseline_results/
# R-Detect feature-reference tensors built from train.jsonl on first run
# (~293 MB each; rebuilt automatically if missing)
data/baseline_artifacts/
# HF Hub cache + NLTK data the vendored R-Detect repo creates inside itself
test/third_party/*/.cache/
test/third_party/*/nltk_data/

# --- transfer / runtime artifacts (regenerate, don't commit) ---
# Feature-cache tarball produced by the cloud-GPU build
features.tar.gz
# GPU-host CLI binary downloaded ad-hoc (platform-specific, not source)
runpodctl
runpodctl.exe
runpodctl-*

# --- multi-seed controlled-set run ---
# Keep models/ready_models_resplit/results/ + scripts/controlled_resplit/,
# but ignore the heavy per-seed weights and feature caches
# (regenerate with scripts/controlled_resplit/run_seed.py)
models/ready_models_resplit/seed*/
data/features_resplit/

# Vendored upstream humanizer repos cloned at runtime by scripts/humanize_*.py
scripts/_workdirs/

# --- backups / one-off scratch ---
# .bak files written by the resplit script and any other backup pattern
*.bak
# Dated local backup snapshots of feature caches / model directories
data/features_*backup*/
models/ready_models_*backup*/
# stale task-output files
*.output
# local copies of remote build logs
build.log
ollama.log

# --- IDE / OS junk ---
.DS_Store
Thumbs.db

.claude